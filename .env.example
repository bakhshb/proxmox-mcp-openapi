# Proxmox VE base URL (include /api2/json)
PROXMOX_URL=https://your-proxmox-host:8006/api2/json

# API Token auth (recommended): username@realm!tokenid=secret
# Create via: Datacenter → Permissions → API Tokens
PROXMOX_API_TOKEN=root@pam!mytoken=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Set to "true" to skip TLS certificate verification (for self-signed certs)
PROXMOX_INSECURE=false

# Request timeout in milliseconds (default: 30000)
# PROXMOX_TIMEOUT=30000

# ─────────────────────────────────────────────
# SSH Configuration (for container command execution)
# The proxmox-execute-container-command tool uses SSH + pct exec
# to run commands inside LXC containers (not available via REST API)
# ─────────────────────────────────────────────

# Path to SSH private key for connecting to Proxmox node
# Default: ~/.ssh/proxmox_mcp
# Generate with: ssh-keygen -t ed25519 -f ~/.ssh/proxmox_mcp
# PROXMOX_SSH_KEY_PATH=~/.ssh/proxmox_mcp

# SSH username for connecting to Proxmox node
# Default: root
# PROXMOX_SSH_USER=root

# SSH port for connecting to Proxmox node
# Default: 22
# PROXMOX_SSH_PORT=22
