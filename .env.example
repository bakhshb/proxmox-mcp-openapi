# Proxmox VE base URL (include /api2/json)
PROXMOX_URL=https://your-proxmox-host:8006/api2/json

# API Token auth (recommended): username@realm!tokenid=secret
# Create via: Datacenter → Permissions → API Tokens
PROXMOX_API_TOKEN=root@pam!mytoken=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ticket-based auth (alternative to API token)
# PROXMOX_TICKET=PVE:root@pam:...
# PROXMOX_CSRF_TOKEN=...

# Set to "true" to skip TLS certificate verification (for self-signed certs)
PROXMOX_INSECURE=false

# Request timeout in milliseconds (default: 30000)
# PROXMOX_TIMEOUT=30000
